# ============================================================
# RAGStudio 环境变量配置（示例）
# ============================================================
# 将此文件复制为 .env 并填入实际值
# cp .env-example .env
# ============================================================

# ----------------------
# 数据库配置（PostgreSQL）
# ----------------------
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_URL=jdbc:postgresql://localhost:5432/ragstudio

# ----------------------
# Redis 配置
# ----------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ----------------------
# RocketMQ 配置
# ----------------------
ROCKETMQ_NAMESERVER=localhost:9876

# ----------------------
# RustFS (S3 兼容对象存储) 配置
# ----------------------
RUSTFS_URL=http://localhost:9000
RUSTFS_ACCESS_KEY=your_access_key
RUSTFS_SECRET_KEY=your_secret_key

# 是否保存ai对话日志，生产环境务必关闭！
SAVE_AI_LOG=false

# ----------------------
# 服务端口
# ----------------------
SERVER_PORT=9090

# ----------------------
# 文件上传限制
# ----------------------
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=100MB

# ----------------------
# 语义裁剪服务
# ----------------------
SEMANTIC_HIGHLIGHT_ENABLED=true
SEMANTIC_HIGHLIGHT_BASE_URL=http://localhost:8001
SEMANTIC_HIGHLIGHT_READ_TIMEOUT=120s

# ----------------------
# Docker 沙箱
# ----------------------
SANDBOX_ENABLED=true
SANDBOX_IMAGE=sandbox:latest

# ----------------------
# 会话令牌过期时间（秒，默认 30 天）
# ----------------------
TOKEN_TIMEOUT=2592000

# ----------------------
# 并发对话限制
# ----------------------
MAX_CONCURRENT=1

# ----------------------
# 链路追踪
# ----------------------
TRACE_ENABLED=true

# ----------------------
# 默认检索数量
# ----------------------
DEFAULT_TOP_K=10

# ----------------------
# 演示模式
# ----------------------
DEMO_MODE=false

# ----------------------
# 默认头像 URL
# ----------------------
DEFAULT_AVATAR_URL=https://avatars.githubusercontent.com/u/583231?v=4
